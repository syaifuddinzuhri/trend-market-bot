# ── MT5 Account ──────────────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── Trading Settings ─────────────────────────────────────────────
SYMBOL=XAUUSD
ACCOUNT_CURRENCY=IDR    # mata uang akun broker
RISK_PERCENT=1.0
FIXED_LOT=0.02          # jika > 0, pakai lot ini (abaikan RISK_PERCENT)
MAGIC_NUMBER=202406
SLIPPAGE=20

# ── Session Filter (WIB / UTC+7) ─────────────────────────────────
SESSION_START_WIB=13
SESSION_END_WIB=1

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── SL dinamis (ATR-based) ───────────────────────────────────────
ATR_SL_MULTIPLIER=1.5     # SL = swing H1 ± ATR_H1 × multiplier ini

# ── TP 3-tier ────────────────────────────────────────────────────
TP1_R=1.0                 # target profit tier-1 (×SL distance)
TP1_PCT=0.30              # % posisi ditutup di TP1
TP2_R=2.0                 # target profit tier-2
TP2_PCT=0.40              # % posisi ditutup di TP2 (sisa 30% trailing)

# ── Breakeven ────────────────────────────────────────────────────
BREAKEVEN_R=1.0           # pindah SL ke entry saat profit = 1R

# ── Pyramid entry ────────────────────────────────────────────────
PYRAMID_ENABLED=true
PYRAMID_LOT_RATIO=0.5     # lot pyramid = lot_awal × ratio ini
MAX_PYRAMID=1             # maksimal pyramid per trade induk

# ── Trade Limits ─────────────────────────────────────────────────
MAX_TRADES_PER_DAY=5

# ── Logging ──────────────────────────────────────────────────────
LOG_DB=logs/trades.db
LOG_CSV=logs/trades.csv

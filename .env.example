# ─────────────────────────────────────────────────────────────────
# TrendBot — XAUUSD Trend Following Bot
# Salin file ini menjadi .env lalu isi nilai yang kosong
# ─────────────────────────────────────────────────────────────────

# ── MT5 Account ──────────────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── Trading Settings ─────────────────────────────────────────────
SYMBOL=XAUUSD
ACCOUNT_CURRENCY=IDR      # mata uang akun broker (IDR / USD / dst)
RISK_PERCENT=1.0          # % balance yang di-risk per trade (jika FIXED_LOT=0)
FIXED_LOT=0.02            # lot tetap; set 0 untuk pakai RISK_PERCENT otomatis
MAGIC_NUMBER=202406       # ID unik bot di MT5
SLIPPAGE=20               # maksimal slippage dalam points

# ── Session Filter (WIB / UTC+7) ─────────────────────────────────
SESSION_START_WIB=13      # jam mulai sesi (13:00 WIB)
SESSION_END_WIB=1         # jam akhir sesi (01:00 WIB hari berikutnya)

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=           # token dari @BotFather
TELEGRAM_CHAT_ID=         # chat ID tujuan notifikasi

# ── Indikator ────────────────────────────────────────────────────
ADX_MIN=25                # threshold ADX minimum untuk BOS entry (CHoCH = ADX_MIN + 5)
ATR_MA_RATIO=0.85         # ATR filter: ATR harus >= ATR_MA × ratio (0.85 = toleransi 15% di bawah MA)

# ── Pending Order (Limit) ─────────────────────────────────────────
PENDING_ENABLED=true          # aktifkan fitur sell/buy limit otomatis
PENDING_MIN_FILTERS=5         # min filter lolos untuk pasang pending
PENDING_EXPIRY_MINUTES=120    # auto-expire setelah 2 jam
PENDING_MAX_DISTANCE_ATR=3.0  # cancel jika harga terlalu jauh dari level

# ── SL Dinamis (ATR-based) ───────────────────────────────────────
ATR_SL_MULTIPLIER=1.0     # SL = swing ± (ATR_H1 × multiplier)
MAX_SL_POINTS=30.0        # cap SL distance maksimal dalam pips (0 = tidak di-cap)
SWING_LOOKBACK_M5=10      # lookback bar M5 untuk swing SL

# ── TP 3-Tier ────────────────────────────────────────────────────
TP1_R=1.0                 # tier-1: target profit dalam satuan R
TP1_PCT=0.30              # % posisi ditutup di TP1 (30%)
TP2_R=2.0                 # tier-2: target profit dalam satuan R
TP2_PCT=0.40              # % posisi ditutup di TP2 (40%), sisa 30% trailing EMA20 H1

# ── Breakeven ────────────────────────────────────────────────────
BREAKEVEN_R=1.0           # pindah SL ke entry saat profit mencapai 1R

# ── Pyramid Entry ────────────────────────────────────────────────
PYRAMID_ENABLED=true      # aktifkan pyramid setelah BE + TP1 hit
PYRAMID_LOT_RATIO=0.5     # lot pyramid = lot_induk × ratio (50%)
MAX_PYRAMID=1             # maksimal 1 pyramid per posisi induk

# ── Multi-Entry Mid-Session ──────────────────────────────────────
MAX_CONCURRENT_POSITIONS=2   # maksimal posisi induk berjalan bersamaan
MIN_ENTRY_INTERVAL=30        # jarak waktu minimum antar entry baru (menit)
MIN_ENTRY_DISTANCE_ATR=1.0   # jarak harga minimum antar entry (× ATR H1)

# ── Trade Limits ─────────────────────────────────────────────────
MAX_TRADES_PER_DAY=5      # maksimal entry induk per hari (0 = unlimited)

# ── Scalper M5 Grid ──────────────────────────────────────────────
SCALP_ENABLED=true
SCALP_MAGIC=202407           # magic number berbeda dari bot utama
SCALP_GRID_COUNT=5           # jumlah pending order per zona (1-10)
SCALP_LOT=0.05               # total lot dibagi grid (0.05 / 5 = 0.01 per order)
SCALP_SL_PIPS=8              # stop loss dalam pip
SCALP_TP_PIPS=15             # take profit dalam pip (1:1.8)
SCALP_EXPIRY_MINUTES=20      # auto-cancel pending setelah N menit
SCALP_ZONE_LOOKBACK=100      # bar M5 untuk scan S&D zone
SCALP_MAX_ZONES=3            # maks zona yang dideteksi
SCALP_ADX_MIN=20             # ADX minimum M5
SCALP_MAX_OPEN=10            # maks posisi scalp terbuka bersamaan
SCALP_CHECK_INTERVAL=10      # detik antar cycle

# ── Logging ──────────────────────────────────────────────────────
LOG_DB=logs/trades.db
LOG_CSV=logs/trades.csv

# ── Scalper Trend ─────────────────────────────────────────────────
TREND_TP_PIPS=15
TREND_SL_PIPS=15
TREND_LOT=0.01
TREND_MAX_OPEN=3
TREND_COOLDOWN=60
TREND_ADX_MIN=20
TREND_MAGIC=202408
TREND_BOTH_DIRECTIONS=false   # true = entry SELL & BUY bergantian (oscillation mode)
TREND_ENTRY_TF=M15            # M15 atau M5
TREND_USE_ZONES=true          # filter S&D zone — hanya entry jika harga di zona
TREND_ZONE_TOLERANCE=0.5      # buffer zona dalam harga (0.5 = 5 pip untuk gold)
TREND_ZONE_LOOKBACK=100       # bar M15 untuk scan zona S&D

REENTRY_ENABLED=true
REENTRY_WINDOW_MINUTES=90   # window setelah TP
REENTRY_MAX_COUNT=2          # max re-entry per sesi tren

ALERT_COOLDOWN_SECONDS=300   # cooldown antar alert manual Telegram (detik), set 0 untuk nonaktifkan